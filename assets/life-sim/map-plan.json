  "implementationOrder": [
    "keep PUBG-style camera as the default Life Sim camera",
    "use this map plan as the source for future map-zone JSON extraction",
    "make routes visible in the phone map before adding more physical land",
    "replace one critical asset per district before adding decorative props",
    "test mobile entry after every Objaverse batch"
  ],
  "redLines": [
    "do not expand into a full Singapore map before the compact district feels alive",
    "do not add decorative Objaverse props that do not support a life choice or place identity",
    "do not block gameplay while optional models load",
    "do not let UI cover the over-shoulder street view",
    "do not make game logic depend on decorative mesh names or downloaded asset success"
  ]
