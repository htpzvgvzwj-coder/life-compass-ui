{
  "version": "2026-07-22-lifeverse-singapore-urban-plan-v2",
  "title": "LifeVerse Singapore District Map Plan",
  "northStar": "A playable adult-life simulator where daily movement, choices, trade-offs, and consequences are readable in the world.",
  "camera": {
    "profile": "pubg-style-over-shoulder",
    "orientation": "landscape-first",
    "playerScreenAnchor": "left-third",
    "fov": 68,
    "distanceMeters": 5.2,
    "movingDistanceMeters": 4.75,
    "shoulderOffsetMeters": 1.18,
    "lookAheadMeters": 7.25,
    "lookHeightMeters": 1.62,
    "inputModel": {
      "mobileMove": "left virtual joystick",
      "mobileLook": "right-side drag",
      "desktopMove": "WASD",
      "desktopLook": "mouse drag"
    },
    "avoid": [
      "top-down dashboard camera",
      "high floating city-view camera",
      "camera centered directly behind the character with no shoulder offset",
      "UI covering the forward street view"
    ]
  },
  "performanceBudget": {
    "target": "smooth mobile web entry before visual completeness",
    "maxPixelRatio": 1.35,
    "shadowMapSize": 1024,
    "firstEntryCriticalAssetBudgetMb": 18,
    "totalBackgroundAssetBudgetMb": 45,
    "nearAssetConcurrency": 3,
    "farAssetConcurrency": 2,
    "roadPropsDelayMs": 900,
    "plazaPropsDelayMs": 1500,
    "farAssetDelayMs": 900,
    "streamingRules": [
      "load spawn district and adjacent route first",
      "delay far districts until after first playable frame",
      "load Objaverse props only when the placement needs that category",
      "never preload the full Objaverse manifest payload on entry",
      "reuse cached models through the asset manager",
      "create simple collision proxies separate from decorative meshes",
      "keep gameplay active when optional assets fail"
    ],
    "objaverseRules": {
      "requiredManifestFields": [
        "id",
        "url",
        "category",
        "license",
        "sourceUrl",
        "targetHeightMeters"
      ],
      "allowedInitialTiers": [
        "critical",
        "near"
      ],
      "backgroundTiers": [
        "background",
        "decorative"
      ],
      "maxCriticalModelsPerDistrict": 3,
      "maxDecorativePropsPerZone": 3,
      "fallbackPolicy": "If an Objaverse asset fails, keep the procedural location and continue play."
    }
  },
  "urbanPlanningPrinciples": [
    {
      "id": "polycentric-town",
      "sourceModel": "Singapore decentralised town planning",
      "rule": "Life Sim should read as one compact regional centre instead of isolated destinations on empty land.",
      "implementedBy": [
        "Integrated MRT and bus interchange",
        "town centre plaza",
        "CBD and regional commercial density",
        "direct routes from housing to work, learning, and services"
      ]
    },
    {
      "id": "hdb-neighbourhood-centre",
      "sourceModel": "HDB town and neighbourhood centre planning",
      "rule": "Housing must be surrounded by everyday services and shared spaces, not only tall blocks.",
      "implementedBy": [
        "HDB precinct court",
        "void deck activity space",
        "clinic, minimart, coffee shop frontages",
        "pavilion, playground, and parking/drop-off bays"
      ]
    },
    {
      "id": "active-ground-floor",
