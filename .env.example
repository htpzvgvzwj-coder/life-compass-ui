COMPASS_AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Optional Gemini fallback. Only used when COMPASS_AI_PROVIDER=gemini.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional OpenAI fallback. Only used when COMPASS_AI_PROVIDER=openai.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
PORT=5179

# Community tab backend (Supabase). Create a project at supabase.com, run
# docs/community-schema.sql in its SQL editor, then copy these 3 values from
# Project Settings > API. SUPABASE_URL and SUPABASE_ANON_KEY are safe to expose
# to the browser (paired with Row Level Security). SUPABASE_SERVICE_ROLE_KEY
# is a secret - it is only ever read server-side, never sent to the client.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
